{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:dev": "vite build --mode development",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "copy-models": "node -e \"const fs=require('fs');const src='node_modules/@vladmandic/face-api/model';const dst='public/models';if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(src+'/'+f,dst+'/'+f));console.log('Models copied.');\"",
    "postinstall": "npm run copy-models"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@vladmandic/face-api": "^1.7.15",
    "dexie": "^4.4.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.2",
    "lovable-tagger": "^1.1.13",
    "lucide-react": "^0.344.0",
    "onnxruntime-web": "^1.20.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^4.5.3"
  }
}
